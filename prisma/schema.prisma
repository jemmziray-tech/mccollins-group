// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 1. NEXTAUTH SECURITY MODELS (Required)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. YOUR BUSINESS MODELS
// ==========================================

// --- USERS (Merged with NextAuth) ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? 
  image         String?   
  password      String?   
  role          String    @default("CUSTOMER") 
  
  // Relations
  accounts      Account[] 
  sessions      Session[] 
  orders        Order[]   
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- PRODUCTS (The Inventory) ---
model Product {
  id            String      @id @default(cuid())
  name          String
  description   String?
  price         Float
  brand         String   
  imageUrl      String
  
  // 🟢 NEW: The lifestyle swap image for our luxury hover effect!
  hoverImageUrl String?     
  
  category      String      @default("Uncategorized")
  
  // Existing fields
  department    String      @default("Unisex") 
  sizes         String[]    @default([])
  sizeType      String      @default("none") 
  isAvailable   Boolean     @default(true)
  
  orderItems    OrderItem[] 
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  stock Int @default(10)
}

// --- ORDERS (Customer Purchases) ---
model Order {
  id            String      @id @default(cuid())
  userId        String?     
  user          User?       @relation(fields: [userId], references: [id])
  customerName  String?    
  customerPhone String?
  items         OrderItem[] 
  totalAmount   Float
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// --- ORDER ITEMS (What's inside the order) ---
model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int
  size            String?  
  priceAtPurchase Float    
}

// --- MARKETING & CAMPAIGNS ---
model HeroCampaign {
  id              String   @id @default("main_campaign") // We only need one active record!
  title           String   @default("Elevate Your Everyday.")
  subtitle        String?  @default("Premium fashion curated for Tanzania.")
  buttonText      String   @default("DISCOVER THE COLLECTION")
  buttonLink      String   @default("/products")
  backgroundImage String   @default("https://images.unsplash.com/photo-1593030761757-71fae4630b05?q=80&w=2000&auto=format&fit=crop")
  updatedAt       DateTime @updatedAt
}

model TrustBadge {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedCart {
  id            String   @id @default(cuid())
  whatsapp      String
  cartItems     Json     // 🟢 We use Json to easily save whatever is in their cart
  status        String   @default("Pending") // Can be: Pending, Contacted, Recovered
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model BespokeRequest {
  id           String   @id @default(cuid())
  clientName   String
  whatsapp     String
  productName  String
  measurements Json     // 🟢 Stores their specific sizes (Chest, Waist, etc.)
  designNotes  String?  // 🟢 Stores their custom style requests
  status       String   @default("Pending Review") // Pending, In Production, Completed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}